<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Exclusive - Monet Request</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #121212; /* Warna gelap agar lebih premium */
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .box {
            background: #1e1e1e;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.5);
            width: 90%;
            max-width: 380px;
            text-align: center;
            border: 1px solid #333;
        }
        input, textarea {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border: 1px solid #444;
            border-radius: 8px;
            background: #2a2a2a;
            color: white;
            box-sizing: border-box;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 15px;
            margin-top: 10px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-blue { background-color: #007bff; color: white; }
        .btn-green { background-color: #25d366; color: white; } /* Warna WhatsApp */
        .btn-red { background-color: #dc3545; color: white; margin-top: 20px; }
        
        /* Box EXCLUSIVE */
        .exclusive-box {
            background: linear-gradient(45deg, #ffd700, #ff8c00);
            color: black;
            padding: 10px;
            border-radius: 8px;
            font-weight: bold;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
            box-shadow: 0 4px 10px rgba(255, 215, 0, 0.3);
        }

        .hidden { display: none; }
        .link { color: #aaa; cursor: pointer; margin-top: 15px; display: block; font-size: 14px; }
    </style>
</head>
<body>

    <!-- HALAMAN LOGIN -->
    <div id="pageLogin" class="box">
        <h2>Login Access</h2>
        <input type="text" id="logUser" placeholder="Username">
        <input type="password" id="logPass" placeholder="Password">
        <button class="btn-blue" onclick="aksiLogin()">LOGIN</button>
        <span class="link" onclick="bukaDaftar()">Belum punya akun? Daftar disini</span>
    </div>

    <!-- HALAMAN DAFTAR -->
    <div id="pageDaftar" class="box hidden">
        <h2>Register</h2>
        <input type="text" id="regUser" placeholder="Buat Username">
        <input type="password" id="regPass" placeholder="Buat Password">
        <button class="btn-blue" style="background-color: #555;" onclick="aksiDaftar()">BUAT AKUN</button>
        <span class="link" onclick="bukaLogin()">Sudah punya akun? Login</span>
    </div>

    <!-- HALAMAN EXCLUSIVE (SETELAH LOGIN) -->
    <div id="pageExclusive" class="box hidden">
        <div class="exclusive-box">👑 EXCLUSIVE 👑</div>
        <p id="txtWelcome" style="margin-bottom: 20px; color: #bbb;"></p>
        
        <label style="display: block; text-align: left; font-size: 14px; color: #ffd700;">Request Monet :</label>
        <textarea id="txtMonet" rows="4" placeholder="Ketik permintaan monetisasi Anda di sini..."></textarea>
        
        <button class="btn-green" onclick="kirimKeWA()">KIRIM REQUEST</button>
        
        <button class="btn-red" onclick="aksiLogout()">LOGOUT</button>
    </div>

    <script>
        // Data Default
        if (!localStorage.getItem('database_user')) {
            localStorage.setItem('database_user', JSON.stringify([{ u: "patrick", p: "kucing123" }]));
        }

        function aksiLogin() {
            let uIn = document.getElementById('logUser').value;
            let pIn = document.getElementById('logPass').value;
            let data = JSON.parse(localStorage.getItem('database_user'));

            let user = data.find(item => item.u === uIn && item.p === pIn);

            if (user) {
                document.getElementById('pageLogin').classList.add('hidden');
                document.getElementById('pageExclusive').classList.remove('hidden');
                document.getElementById('txtWelcome').innerText = "Selamat datang, " + uIn + "!";
            } else {
                alert("Username atau Password Salah!");
            }
        }

        function aksiDaftar() {
            let uBaru = document.getElementById('regUser').value;
            let pBaru = document.getElementById('regPass').value;
            if(!uBaru || !pBaru) return alert("Isi semua data!");

            let data = JSON.parse(localStorage.getItem('database_user'));
            if (data.some(i => i.u === uBaru)) return alert("Username sudah ada!");

            data.push({ u: uBaru, p: pBaru });
            localStorage.setItem('database_user', JSON.stringify(data));
            alert("Berhasil Daftar!");
            bukaLogin();
        }

        // FITUR KIRIM KE WHATSAPP
        function kirimKeWA() {
            let pesanRequest = document.getElementById('txtMonet').value;
            let nomorWA = "6287824281860"; // Nomor tujuan

            if (pesanRequest.trim() === "") {
                alert("Harap isi kotak Request Monet sebelum mengirim!");
                return;
            }

            // Format pesan yang akan dikirim
            let textKirim = encodeURIComponent("Halo Admin, saya ingin Request Monet:\n\n" + pesanRequest);
            
            // Membuka WhatsApp di tab baru
            let url = "https://wa.me/" + nomorWA + "?text=" + textKirim;
            window.open(url, '_blank');
        }

        function bukaDaftar() {
            document.getElementById('pageLogin').classList.add('hidden');
            document.getElementById('pageDaftar').classList.remove('hidden');
        }
        function bukaLogin() {
            document.getElementById('pageDaftar').classList.add('hidden');
            document.getElementById('pageLogin').classList.remove('hidden');
        }
        function aksiLogout() {
            location.reload();
        }
    </script>
</body>
</html>
